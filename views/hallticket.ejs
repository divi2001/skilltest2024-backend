        }

        .info-title {
            padding-right: 8px;
        }

        .student-details3 {
            position: absolute;
            top: 701px;
            left: 14.4px;
            border: solid black 2px;
            border-collapse: collapse;
            padding: 0;
        }

        .table2-fields {
            padding-top: 8px;
            padding-bottom: 8px;
            padding-right: 5px;
        }

        .student-details3 th {
            font-size: small;
            font-weight: 400;
            border: solid black 2px;
            padding-left: 5px;

        }

        .invigilatorname {
            position: relative;
            top: 40px;
            left: 20px;
            text-align: center;
            padding-right: 34px;
        }

        .exam-center {
            position: absolute;
            top: 854px;
            left: 15px;
            border: solid black 2px;
            border-collapse: collapse;
